# ============================================================
# .gitignore — Wipro Capstone Project
# Files/Folders Git should NOT upload to GitHub
# ============================================================


# ============================================================
# Python Cache Files
# Auto-generated by Python
# ============================================================
__pycache__/
*.py[cod]
*.pyo


# ============================================================
# Virtual Environment
# Contains installed packages (large size)
# Recreated using: pip install -r requirements.txt
# ============================================================
.venv/
venv/
env/


# ============================================================
# pytest Cache
# Auto-generated after pytest execution
# ============================================================
.pytest_cache/


# ============================================================
# IDE / Editor Files
# Personal IDE settings
# ============================================================
.idea/
.vscode/
*.iml


# ============================================================
# WebDriver Manager Cache
# ChromeDriver auto-download cache
# ============================================================
.wdm/


# ============================================================
# Environment Variables
# Sensitive/private data
# ============================================================
.env


# ============================================================
# Windows System Files
# ============================================================
Thumbs.db
Desktop.ini